# App
APP_NAME=SymptoScan API
APP_ENV=development
PORT=8000

# Frontend origin(s) for CORS (comma-separated)
FRONTEND_ORIGIN=http://127.0.0.1:5500

# Optional: store request history in SQLite
STORE_HISTORY=true
DATABASE_PATH=./symptoscan.db

# LLM configuration (optional but recommended)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1-mini

# Optional timeout (seconds)
LLM_TIMEOUT=25

# Optional: use LangChain tool-calling agent before direct LLM path
USE_LANGCHAIN_AGENT=true

# Local terminal logging for demo/testing
DEBUG_LOGS=true
